{
  "name": "zcashskills",
  "version": "1.0.0",
  "description": "Privacy-preserving ZCash skills for AI agents with local cryptographic operations",
  "main": "lib/index.js",
  "keywords": [
    "zcash",
    "privacy",
    "ai-agents",
    "cryptocurrency",
    "openclaw",
    "blockchain",
    "skills",
    "payments",
    "crypto"
  ],
  "author": "konradgnat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/konradgnat/zcashskills.git"
  },
  "homepage": "https://github.com/konradgnat/zcashskills#readme",
  "bugs": {
    "url": "https://github.com/konradgnat/zcashskills/issues"
  },
  "scripts": {
    "test": "jest",
    "test:unit": "jest test/unit",
    "test:integration": "jest test/integration",
    "build": "cargo build --release --manifest-path native/Cargo.toml && cp native/index.node prebuilds/darwin-arm64/zcash-native.node",
    "install": "node scripts/install.js",
    "prebuild": "prebuildify --napi --strip",
    "rebuild": "npm run build",
    "lint": "eslint lib/ skills/ examples/",
    "docs": "jsdoc -c jsdoc.conf.json",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "bindings": "^1.5.0"
  },
  "devDependencies": {
    "@neon-rs/cli": "^0.1.82",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.0",
    "node-addon-api": "^8.6.0",
    "prebuildify": "^6.0.0"
  },
  "files": [
    "lib/",
    "skills/",
    "prebuilds/",
    "examples/",
    "docs/",
    "native/src/",
    "native/Cargo.toml",
    "native/build.rs"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "napi": {
    "name": "zcash-native"
  }
}
